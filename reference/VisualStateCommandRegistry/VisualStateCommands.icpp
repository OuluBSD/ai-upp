#include "VisualStateCommandRegistry.h"

namespace Upp {

static String VsmCommandExeName(const String& base)
{
#ifdef flagWIN32
	return base + ".exe";
#else
	return base;
#endif
}

static String VsmCommandBinDir(CoreCommandContext& context)
{
	String bin_dir = context.Get("bin_dir", "");
	return bin_dir.IsEmpty() ? GetExeFolder() : bin_dir;
}

static CoreCommandResult RunVsmProcessCommand(CoreCommandContext& context, const String& exe_base, const Vector<String>& args)
{
	CoreCommandResult result;
	String app = AppendFileName(VsmCommandBinDir(context), VsmCommandExeName(exe_base));
	ValueMap value;
	value.Add("app", app);
	ValueArray arg_values;
	for(const String& arg : args)
		arg_values.Add(arg);
	value.Add("args", arg_values);

	if(!FileExists(app)) {
		result.ok = false;
		result.code = 127;
		result.message = "Executable not found: " + app;
		result.value = value;
		return result;
	}

	String out;
	int code = Sys(app, args, out);
	value.Add("exit_code", code);
	value.Add("stdout", out);
	result.ok = code == 0;
	result.code = code;
	result.message = result.ok ? exe_base + " completed" : exe_base + " failed";
	result.value = value;
	return result;
}

static CoreCommandResult VsmCommandArgError(const String& message)
{
	CoreCommandResult result;
	result.ok = false;
	result.code = 2;
	result.message = message;
	return result;
}

struct VsmModelSmokeCommand {
	static void Setup(CoreCommand& command)
	{
		command.description = "Runs the VisualStateModel headless smoke test executable.";
		command.category = "vsm";
		command.tags << "vsm" << "smoke" << "process";
		command.args_schema.Add("bin_dir", "optional directory containing VisualStateModelTest executable");
		command.handler = [](CoreCommandContext& context) {
			Vector<String> args;
			return RunVsmProcessCommand(context, "VisualStateModelTest", args);
		};
	}
};

