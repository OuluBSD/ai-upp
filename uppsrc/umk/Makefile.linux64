
UPPOUT = _out/
CINC   =  `pkg-config --cflags libpng` `pkg-config --cflags freetype2` `pkg-config --cflags fontconfig` `pkg-config --cflags x11` `pkg-config --cflags xcb` `pkg-config --cflags expat` -I./ -I$(UPPOUT)
Macro  =  -DflagCLANG -DflagDEBUG -DflagSHARED -DflagDEBUG_FULL -DflagPOSIX -DflagLINUX
CXX = c++
LINKER = $(CXX)
CFLAGS = -D_DEBUG -mpopcnt -O0 -ggdb -g2 
CXXFLAGS = -D_DEBUG -mpopcnt -O0 -ggdb -g2  -std=c++17 -Wno-logical-op-parentheses
LDFLAGS =  $(LINKOPTIONS)
LIBPATH =
AR = ar -sr

OutDir_umk = $(UPPOUT)umk/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Main-Posix-Shared/
Macro_umk = $(Macro) -DflagBLITZ -DflagMAIN
OutDir_ide_Builders = $(UPPOUT)ide/Builders/CLANG-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_ide_Builders = $(Macro)
OutDir_ide_Core = $(UPPOUT)ide/Core/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_ide_Core = $(Macro) -DflagBLITZ
OutDir_ide_Java = $(UPPOUT)ide/Java/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_ide_Java = $(Macro) -DflagBLITZ
OutDir_ide_Android = $(UPPOUT)ide/Android/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_ide_Android = $(Macro) -DflagBLITZ
OutDir_plugin_png = $(UPPOUT)plugin/png/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_plugin_png = $(Macro) -DflagBLITZ
OutDir_Draw = $(UPPOUT)Draw/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_Draw = $(Macro) -DflagBLITZ
OutDir_Esc = $(UPPOUT)Esc/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_Esc = $(Macro) -DflagBLITZ
OutDir_plugin_bz2 = $(UPPOUT)plugin/bz2/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_plugin_bz2 = $(Macro) -DflagBLITZ
OutDir_plugin_lzma = $(UPPOUT)plugin/lzma/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_plugin_lzma = $(Macro) -DflagBLITZ
OutDir_plugin_lz4 = $(UPPOUT)plugin/lz4/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_plugin_lz4 = $(Macro) -DflagBLITZ
OutDir_plugin_zstd = $(UPPOUT)plugin/zstd/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_plugin_zstd = $(Macro) -DflagBLITZ
OutDir_Core = $(UPPOUT)Core/CLANG-Blitz-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_Core = $(Macro) -DflagBLITZ
OutDir_plugin_pcre = $(UPPOUT)plugin/pcre/CLANG-Clang-Debug-Debug_Full-Linux-Posix-Shared/
Macro_plugin_pcre = $(Macro)

OutDir = $(OutDir_umk)
OutFile = umk.out

.PHONY: all
all: prepare $(OutFile)

.PHONY: build_info
build_info:
	(date '+#define bmYEAR    %y%n#define bmMONTH   %m%n#define bmDAY     %d%n#define bmHOUR    %H%n#define bmMINUTE  %M%n#define bmSECOND  %S%n#define bmTIME    Time( %y, %m, %d, %H, %M, %S )' | sed 's| 0\([[:digit:]]\)| \1|g' && \
	echo '#define bmMACHINE "'`hostname`'"' && \
	echo '#define bmUSER    "'`whoami`'"') > "$(UPPOUT)/build_info.h"
	echo '#define bmGIT_REVCOUNT "19344"' >> "$(UPPOUT)/build_info.h"
	echo '#define bmGIT_HASH "b57b85dd3ccbc44b55667f75bda67493be5d922a"' >> "$(UPPOUT)/build_info.h"
	echo '#define bmGIT_BRANCH "master"' >> "$(UPPOUT)/build_info.h"

.PHONY: prepare
prepare: \
	$(OutDir_umk) \
	$(OutDir_ide_Builders) \
	$(OutDir_ide_Core) \
	$(OutDir_ide_Java) \
	$(OutDir_ide_Android) \
	$(OutDir_plugin_png) \
	$(OutDir_Draw) \
	$(OutDir_Esc) \
	$(OutDir_plugin_bz2) \
	$(OutDir_plugin_lzma) \
	$(OutDir_plugin_lz4) \
	$(OutDir_plugin_zstd) \
	$(OutDir_Core) \
	$(OutDir_plugin_pcre)

$(OutFile): build_info  \
	$(OutDir_umk)Console.o \
	$(OutDir_umk)IdeContext.o \
	$(OutDir_umk)MakeBuild.o \
	$(OutDir_umk)Export.o \
	$(OutDir_umk)UppHub.o \
	$(OutDir_umk)umake.o \
	$(OutDir_ide_Builders)Builders.a \
	$(OutDir_ide_Core)Core.a \
	$(OutDir_ide_Java)Java.a \
	$(OutDir_ide_Android)Android.a \
	$(OutDir_plugin_png)pngreg.o \
	$(OutDir_plugin_png)png.a \
	$(OutDir_Draw)Draw.a \
	$(OutDir_Esc)Esc.a \
	$(OutDir_plugin_bz2)bz2.a \
	$(OutDir_plugin_lzma)lzma.a \
	$(OutDir_plugin_lz4)lz4.a \
	$(OutDir_plugin_zstd)zstd.a \
	$(OutDir_Core)Core.a \
	$(OutDir_plugin_pcre)pcre.a
	$(LINKER) -o "$(OutFile)" -ggdb $(LIBPATH) -Wl,-O,2 $(LDFLAGS) -Wl,--start-group  \
		$(OutDir_umk)Console.o \
		$(OutDir_umk)IdeContext.o \
		$(OutDir_umk)MakeBuild.o \
		$(OutDir_umk)Export.o \
		$(OutDir_umk)UppHub.o \
		$(OutDir_umk)umake.o \
			$(OutDir_ide_Builders)Builders.a \
			$(OutDir_ide_Core)Core.a \
			$(OutDir_ide_Java)Java.a \
			$(OutDir_ide_Android)Android.a \
		$(OutDir_plugin_png)pngreg.o \
			$(OutDir_plugin_png)png.a \
			$(OutDir_Draw)Draw.a \
			$(OutDir_Esc)Esc.a \
			$(OutDir_plugin_bz2)bz2.a \
			$(OutDir_plugin_lzma)lzma.a \
			$(OutDir_plugin_lz4)lz4.a \
			$(OutDir_plugin_zstd)zstd.a \
			$(OutDir_Core)Core.a \
			$(OutDir_plugin_pcre)pcre.a \
			`pkg-config --libs libpng` \
			`pkg-config --libs freetype2` \
			`pkg-config --libs fontconfig` \
			`pkg-config --libs x11` \
			`pkg-config --libs xcb` \
			`pkg-config --libs expat` \
			-lbz2 \
			-lpthread \
			-ldl \
			-lrt \
			-lz -Wl,--end-group

$(OutDir_umk):
	mkdir -p $(OutDir_umk)

