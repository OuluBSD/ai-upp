description "Standalone Skylark-based browser host for ScriptIDE GameState sessions\377";

uses
	Skylark,
	ScriptCommon,
	ScriptTranspiler;

file
	AGENTS.md,
	CURRENT_TASK.md,
	ScriptWebHost.h,
	App.h,
	App.cpp,
	Handlers.cpp,
	Main.cpp,
	SmokeTest.sh,
	static/runtime.js,
	static/style.css;

mainconfig
	"" = "",
	"USEMALLOC" = "USEMALLOC";
