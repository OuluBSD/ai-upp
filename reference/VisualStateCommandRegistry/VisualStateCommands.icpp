#include "VisualStateCommandRegistry.h"

namespace Upp {

static String VsmCommandExeName(const String& base)
{
#ifdef flagWIN32
	return base + ".exe";
#else
	return base;
#endif
}

static String VsmCommandBinDir(CoreCommandContext& context)
{
	String bin_dir = context.Get("bin_dir", "");
	return bin_dir.IsEmpty() ? GetExeFolder() : bin_dir;
}

static CoreCommandResult RunVsmProcessCommand(CoreCommandContext& context, const String& exe_base, const Vector<String>& args)
{
	CoreCommandResult result;
	String app = AppendFileName(VsmCommandBinDir(context), VsmCommandExeName(exe_base));
	ValueMap value;
	value.Add("app", app);
	ValueArray arg_values;
	for(const String& arg : args)
		arg_values.Add(arg);
	value.Add("args", arg_values);

	if(!FileExists(app)) {
		result.ok = false;
		result.code = 127;
		result.message = "Executable not found: " + app;
		result.value = value;
		return result;
	}

	String out;
	int code = Sys(app, args, out);
	value.Add("exit_code", code);
	value.Add("stdout", out);
	result.ok = code == 0;
	result.code = code;
	result.message = result.ok ? exe_base + " completed" : exe_base + " failed";
	result.value = value;
	return result;
}

static CoreCommandResult VsmCommandArgError(const String& message)
{
	CoreCommandResult result;
	result.ok = false;
	result.code = 2;
	result.message = message;
	return result;
}

static bool VsmCommandBoolArg(CoreCommandContext& context, const String& key, bool fallback)
{
	Value raw = context.Get(key, Null);
	if(IsNull(raw))
		return fallback;
	if(raw.Is<bool>())
		return (bool)raw;
	if(IsNumber(raw))
		return (int)raw != 0;
	String value = ToLower(TrimBoth(AsString(raw)));
	if(value == "1" || value == "true" || value == "yes" || value == "on")
		return true;
	if(value == "0" || value == "false" || value == "no" || value == "off")
		return false;
	return fallback;
}

static int VsmCommandIntArg(CoreCommandContext& context, const String& key, int fallback, int min_value)
{
	Value raw = context.Get(key, Null);
	if(IsNull(raw))
		return fallback;
	if(IsNumber(raw))
		return max(min_value, (int)raw);
	String value = AsString(raw);
	return value.IsEmpty() ? fallback : max(min_value, StrInt(value));
}

static bool VsmCommandStrictIntText(const String& text, int min_value, int& out)
{
	String trimmed = TrimBoth(text);
	const char *end = NULL;
	int value = ScanInt(trimmed, &end);
	if(trimmed.IsEmpty() || !end || *end || value < min_value)
		return false;
	out = value;
	return true;
}

static bool VsmCommandStrictIntArg(CoreCommandContext& context, const String& key, int fallback, int min_value, int& out)
{
	Value raw = context.Get(key, Null);
	if(IsNull(raw)) {
		out = fallback;
		return true;
	}
	if(IsNumber(raw)) {
		double number = (double)raw;
		if(number < INT_MIN || number > INT_MAX)
			return false;
		int value = (int)number;
		if(value != number || value < min_value)
			return false;
		out = value;
		return true;
	}
	return VsmCommandStrictIntText(AsString(raw), min_value, out);
}

static ValueMap VsmArtifactValue(const String& role, const String& path)
{
	ValueMap artifact;
	artifact.Add("role", role);
	artifact.Add("path", path);
	artifact.Add("exists", FileExists(path) || DirectoryExists(path));
	if(FileExists(path))
		artifact.Add("size", GetFileLength(path));
	return artifact;
}

static int VsmCountJsonlRows(const String& path)
{
	if(!FileExists(path))
		return 0;
	Vector<String> rows = Split(LoadFile(path), '\n', false);
	int count = 0;
	for(String row : rows)
		if(!TrimBoth(row).IsEmpty())
			count++;
	return count;
}

static int VsmCountPngFiles(const String& dir)
{
	if(!DirectoryExists(dir))
		return 0;
	int count = 0;
	FindFile ff(AppendFileName(dir, "*.png"));
	while(ff) {
		if(!ff.IsFolder())
			count++;
		ff.Next();
	}
	return count;
}

struct VsmTexasHoldemGroundTruthEvidence {
	int rows = 0;
	bool parse_ok = false;
	bool frame_ids_ok = false;
	String error;
};

static VsmTexasHoldemGroundTruthEvidence VsmReadTexasHoldemGroundTruth(const String& path,
                                                                       int expected_count)
{
	VsmTexasHoldemGroundTruthEvidence evidence;
	if(!FileExists(path)) {
		evidence.error = "groundtruth file missing";
		return evidence;
	}

	evidence.parse_ok = true;
	Vector<String> rows = Split(LoadFile(path), '\n', false);
	for(String row : rows) {
		row = TrimBoth(row);
		if(row.IsEmpty())
			continue;

		Value row_value;
		try {
			row_value = ParseJSON(row);
		}
		catch(...) {
			evidence.parse_ok = false;
			if(evidence.error.IsEmpty())
				evidence.error = Format("groundtruth JSON parse failed at row %d", evidence.rows);
			continue;
		}
		if(!row_value.Is<ValueMap>()) {
			evidence.parse_ok = false;
			if(evidence.error.IsEmpty())
				evidence.error = Format("groundtruth row is not an object at row %d", evidence.rows);
			evidence.rows++;
			continue;
		}

		ValueMap groundtruth = row_value;
		Value frame_value = groundtruth.Get("frame_id", Null);
		if(!IsNumber(frame_value)) {
			evidence.parse_ok = false;
			if(evidence.error.IsEmpty())
				evidence.error = Format("groundtruth frame_id missing or invalid at row %d", evidence.rows);
		}
		else if((int)frame_value != evidence.rows && evidence.error.IsEmpty())
			evidence.error = Format("expected frame_id=%d actual=%d", evidence.rows, (int)frame_value);
		evidence.rows++;
	}

	evidence.frame_ids_ok = evidence.parse_ok && evidence.rows == expected_count && evidence.error.IsEmpty();
	if(evidence.frame_ids_ok)
		evidence.error = Format("frame_id range 0..%d", expected_count - 1);
	else if(evidence.error.IsEmpty())
		evidence.error = Format("expected %d sequential frame ids, actual %d", expected_count, evidence.rows);
	return evidence;
}

static String VsmTexasHoldemFrameName(int frame_id)
{
	return Format("%08d.png", frame_id);
}

static ValueMap VsmLoadJsonObject(const String& path, bool& ok)
{
	ok = false;
	ValueMap out;
	if(!FileExists(path))
		return out;
	try {
		Value value = ParseJSON(LoadFile(path));
		if(value.Is<ValueMap>()) {
			ok = true;
			return value;
		}
	}
	catch(...) {
	}
	return out;
}

static String VsmRepoFilePath(const String& package_dir, const String& filename)
{
	String rel = AppendFileName(package_dir, filename);
	Vector<String> candidates;
	candidates << AppendFileName(GetCurrentDirectory(), rel)
	           << AppendFileName(AppendFileName(GetExeFolder(), ".."), rel);
	for(const String& path : candidates)
		if(FileExists(path))
			return NormalizePath(path);
	return NormalizePath(candidates[0]);
}

static ValueMap VsmTexasHoldemProviderInfoValue(const TexasHoldemProviderInfo& provider)
{
	String package_dir = AppendFileName("game", "TexasHoldem");
	String form_file = provider.form_file;
	String form_path = VsmRepoFilePath(package_dir, form_file);
	ValueMap info;
	info.Add("name", provider.id);
	info.Add("label", provider.label);
	info.Add("layout_profile", provider.layout_profile);
	info.Add("table_profile", provider.table_profile);
	info.Add("form_file", form_file);
	info.Add("form_path", form_path);
	info.Add("form_exists", FileExists(form_path));
	info.Add("default_players", provider.default_players);
	info.Add("available", FileExists(form_path));
	return info;
}

static ValueArray VsmTexasHoldemProviderCatalog()
{
	ValueArray providers;
	for(const TexasHoldemProviderInfo& provider : TexasHoldemListProviders())
		providers.Add(VsmTexasHoldemProviderInfoValue(provider));
	return providers;
}

struct VsmModelSmokeCommand {
	static void Setup(CoreCommand& command)
	{
		command.description = "Runs the VisualStateModel headless smoke test executable.";
		command.category = "vsm";
		command.tags << "vsm" << "smoke" << "process";
		command.args_schema.Add("bin_dir", "optional directory containing VisualStateModelTest executable");
		command.handler = [](CoreCommandContext& context) {
			Vector<String> args;
			return RunVsmProcessCommand(context, "VisualStateModelTest", args);
		};
	}
};

