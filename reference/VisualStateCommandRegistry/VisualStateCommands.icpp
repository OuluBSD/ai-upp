struct VsmSessionValidateCommand {
	static void Setup(CoreCommand& command)
	{
		command.description = "Runs VisualStateSessionValidate in synthetic mode or for a session directory.";
		command.category = "vsm.validation";
		command.tags << "vsm" << "session" << "validation" << "process";
		command.args_schema.Add("bin_dir", "optional directory containing VisualStateSessionValidate executable");
		command.args_schema.Add("session_dir", "optional session directory; omitted runs synthetic self-check");
		command.handler = [](CoreCommandContext& context) {
			Vector<String> args;
			String session_dir = context.Get("session_dir", "");
			if(!session_dir.IsEmpty())
				args << session_dir;
			return RunVsmProcessCommand(context, "VisualStateSessionValidate", args);
		};
	}
};

struct VsmSessionDiffCommand {
	static void Setup(CoreCommand& command)
	{
		command.description = "Runs VisualStateSessionDiff in synthetic mode or compares two session directories.";
		command.category = "vsm.validation";
		command.tags << "vsm" << "session" << "diff" << "process";
		command.args_schema.Add("bin_dir", "optional directory containing VisualStateSessionDiff executable");
		command.args_schema.Add("session_a", "optional first session directory; both session_a and session_b are required for real diff mode");
		command.args_schema.Add("session_b", "optional second session directory; both session_a and session_b are required for real diff mode");
		command.handler = [](CoreCommandContext& context) {
			String session_a = context.Get("session_a", "");
			String session_b = context.Get("session_b", "");
			if(session_a.IsEmpty() != session_b.IsEmpty())
				return VsmCommandArgError("session_a and session_b must be provided together");
			Vector<String> args;
			if(!session_a.IsEmpty()) {
				args << session_a;
				args << session_b;
			}
			return RunVsmProcessCommand(context, "VisualStateSessionDiff", args);
		};
	}
};

